# Streamlit Community Cloud > App settings > Secrets 에 복사해서 사용하세요.
# 실제 값이 들어간 secrets.toml은 GitHub에 올리지 마세요.

OPENAI_API_KEY="sk-..."  # still required for embeddings/retrieval

# Optional experimental chat backend. Works only on a host that has Hermes Codex OAuth auth.json.
WESS_CHAT_PROVIDER="openai"
# WESS_CHAT_PROVIDER="codex-oauth"
# WESS_CODEX_AUTH_FILE="/home/jeong/.hermes/auth.json"
# WESS_CODEX_BASE_URL="https://chatgpt.com/backend-api/codex"
# WESS_CODEX_REASONING_EFFORT="xhigh"
# WESS_CODEX_FALLBACK_MODELS="gpt-5.4"

# Optional
WESS_CHAT_MODEL="gpt-5.5"
WESS_FAST_MODEL="gpt-5.5"
WESS_EMBEDDING_MODEL="text-embedding-3-small"
CHROMA_DIR="./chroma_db"