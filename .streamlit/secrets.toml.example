# Streamlit Community Cloud > App settings > Secrets 에 복사해서 사용하세요.
# 실제 값이 들어간 secrets.toml은 GitHub에 올리지 마세요.

# Default Chroma retrieval uses OpenAI embeddings.
OPENAI_API_KEY="sk-..."

# Retrieval backend: "chroma" or "fts". fts is local keyword/BM25 and needs no OpenAI key.
WESS_RETRIEVAL_PROVIDER="chroma"
# WESS_RETRIEVAL_PROVIDER="fts"

# Chat backend is fixed to the normal OpenAI API path.
WESS_CHAT_PROVIDER="openai"

# Optional
WESS_CHAT_MODEL="gpt-5.4-mini"
WESS_FAST_MODEL="gpt-5.4-mini"
WESS_EMBEDDING_MODEL="text-embedding-3-small"
CHROMA_DIR="./chroma_db"
