# Streamlit Community Cloud > App settings > Secrets 에 복사해서 사용하세요.
# 실제 값이 들어간 secrets.toml은 GitHub에 올리지 마세요.

# Default Chroma retrieval uses OpenAI embeddings.
# For full OAuth text mode, comment this out and set WESS_RETRIEVAL_PROVIDER="fts" below.
OPENAI_API_KEY="sk-..."

# Retrieval backend: "chroma" or "fts". fts is local keyword/BM25 and needs no OpenAI key.
WESS_RETRIEVAL_PROVIDER="chroma"
# WESS_RETRIEVAL_PROVIDER="fts"

# Optional experimental chat backend. Works only on a host that has Hermes Codex OAuth auth.json/token.
WESS_CHAT_PROVIDER="openai"
# WESS_CHAT_PROVIDER="codex-oauth"
# WESS_CODEX_AUTH_FILE="/home/jeong/.hermes/auth.json"
# For Streamlit Cloud, set exactly one of these instead of WESS_CODEX_AUTH_FILE:
# WESS_CODEX_ACCESS_TOKEN="eyJ..."
# WESS_CODEX_AUTH_JSON='{"providers":{"openai-codex":{"tokens":{"access_token":"eyJ..."}}}}'
# WESS_CODEX_BASE_URL="https://chatgpt.com/backend-api/codex"
# WESS_CODEX_REASONING_EFFORT="xhigh"
# WESS_CODEX_FALLBACK_MODELS="gpt-5.4"

# Optional
WESS_CHAT_MODEL="gpt-5.5"
WESS_FAST_MODEL="gpt-5.5"
WESS_EMBEDDING_MODEL="text-embedding-3-small"
CHROMA_DIR="./chroma_db"

# Full OAuth text mode secrets (text-only; no OPENAI_API_KEY required):
# WESS_RETRIEVAL_PROVIDER="fts"
# WESS_CHAT_PROVIDER="codex-oauth"
# WESS_CODEX_ACCESS_TOKEN="eyJ..."
