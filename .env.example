# Required for embeddings/retrieval
# Chat can optionally use WESS_CHAT_PROVIDER=codex-oauth, but embeddings still need OPENAI_API_KEY.
OPENAI_API_KEY=your_openai_api_key_here

# Optional chat backend: openai or codex-oauth (experimental; reads Hermes auth.json)
WESS_CHAT_PROVIDER=openai
# WESS_CODEX_AUTH_FILE=~/.hermes/auth.json
# For Streamlit Cloud/self-hosted secrets without a file, set exactly one of these instead:
# WESS_CODEX_ACCESS_TOKEN=eyJ...
# WESS_CODEX_AUTH_JSON={"providers":{"openai-codex":{"tokens":{"access_token":"eyJ..."}}}}
# WESS_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
# WESS_CODEX_REASONING_EFFORT=xhigh
# 429/usage_limit_reached on gpt-5.5 tries these Codex models first, then falls back to OPENAI_API_KEY.
# WESS_CODEX_FALLBACK_MODELS=gpt-5.4

# Optional models
WESS_CHAT_MODEL=gpt-5.5
WESS_FAST_MODEL=gpt-5.5
WESS_EMBEDDING_MODEL=text-embedding-3-small

# Optional paths/ports
CHROMA_DIR=./chroma_db
API_PORT=5000

# Optional API protection for mobile/backend usage
# If set, clients must send X-API-Key: <value> or Authorization: Bearer <value>
WESS_API_KEY=

# Optional CORS lock-down. Use a specific domain in production.
CORS_ALLOW_ORIGIN=*

# Optional mixed Streamlit+Flask mode. Prefer separate API process in production.
START_EMBEDDED_API=0
