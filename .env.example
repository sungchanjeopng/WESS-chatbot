# Default Chroma retrieval uses OpenAI embeddings.
OPENAI_API_KEY=your_openai_api_key_here

# Retrieval backend: chroma (OpenAI embeddings) or fts (local BM25/keyword, no OpenAI key).
WESS_RETRIEVAL_PROVIDER=chroma

# Chat backend is fixed to the normal OpenAI API path.
WESS_CHAT_PROVIDER=openai

# Optional models
WESS_CHAT_MODEL=gpt-5.4
WESS_FAST_MODEL=gpt-5.4
WESS_EMBEDDING_MODEL=text-embedding-3-small

# Optional paths/ports
CHROMA_DIR=./chroma_db
API_PORT=5000

# Optional API protection for mobile/backend usage
# If set, clients must send X-API-Key: <value> or Authorization: Bearer <value>
WESS_API_KEY=

# Optional CORS lock-down. Use a specific domain in production.
CORS_ALLOW_ORIGIN=*

# Optional mixed Streamlit+Flask mode. Prefer separate API process in production.
START_EMBEDDED_API=0

# Retrieval remains configurable, but chat answers use OPENAI_API_KEY + gpt-5.4.
